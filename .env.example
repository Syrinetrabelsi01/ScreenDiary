# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# TMDb — https://www.themoviedb.org/settings/api
# Prefer the v4 Read Access Token (Bearer). TMDB_API_KEY (v3) is used as a fallback
# if TMDB_BEARER_TOKEN isn't set. You only need one of the two.
TMDB_BEARER_TOKEN=
TMDB_API_KEY=

# AI (ScreenDiary AI page + AI Tools on the item detail page) — optional.
# Leave ANTHROPIC_API_KEY blank and the app runs fine; AI tools just show
# "AI is not configured yet" instead of crashing.
# Get a key at https://console.anthropic.com/settings/keys
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-5
